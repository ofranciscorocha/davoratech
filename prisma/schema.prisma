generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- CORE / HUB MODELS ---

model HubUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- LEILAO MODELS (from Pátio Rocha Leilões) ---

model SystemSettings {
  id                String   @id @default("SETTINGS")
  siteName          String   @default("Pátio Rocha Leilões")
  siteUrl           String?
  logoUrl           String?
  faviconUrl        String?
  enableAuctions    Boolean  @default(true)
  enableBidding     Boolean  @default(true)
  enableUserSignup  Boolean  @default(true)
  maintenanceMode   Boolean  @default(false)
  hideSoldValues    Boolean  @default(false)
  termsOfService    String?
  privacyPolicy     String?
  seoTitle          String?
  seoDescription    String?
  contactEmail      String?
  contactPhone      String?
  address           String?
  updatedAt         DateTime @updatedAt
}

model User {
  id               String               @id @default(cuid())
  name             String?
  email            String               @unique
  password         String
  role             String               @default("USER")
  type             String               @default("PF")
  cpf              String?              @unique
  rg               String?
  orgEmitter       String?
  dispatchDate     DateTime?
  cnh              String?
  cnhIssueDate     DateTime?
  gender           String?
  birthDate        DateTime?
  nationality      String?
  naturalness      String?
  motherName       String?
  maritalStatus    String?
  cnpj             String?              @unique
  corporateName    String?
  tradeName        String?
  stateInscription String?
  responsibleName  String?
  phone            String?
  mobile           String?
  zipCode          String?
  address          String?
  number           String?
  complement       String?
  neighborhood     String?
  city             String?
  state            String?
  status           String               @default("PENDING")
  internalNotes    String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  bids             Bid[]
  wonLots          Lot[]                @relation("LotWinner")
  activeBids       Lot[]                @relation("LotCurrentBidder")
  documents        UserDocument[]
  inspections      VehicleInspection[]
  habilitacoes     AuctionHabilitacao[]

  // Recicladora Relations
  accounts         Account[]
  sessions         Session[]
  salvados         Salvado[]
  comments         Comment[]
}

model UserDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  status    String   @default("PENDING")
  fileUrl   String
  createdAt DateTime @default(now())
}

model Auction {
  id                  String               @id @default(cuid())
  title               String
  description         String?
  summary             String?
  coverImage          String?
  status              String               @default("UPCOMING")
  type                String               @default("ONLINE")
  modalidade          String?
  singleComitente     Boolean              @default(false)
  hideDates           Boolean              @default(false)
  squares             String               @default("UNIQUE")
  biddingStart        DateTime?
  startDate           DateTime
  endDate             DateTime
  visitationInfo      String?
  enableGuestBids     Boolean              @default(false)
  audienceRestriction String               @default("ALL")
  paymentInstallments Boolean              @default(false)
  maskUser            String               @default("PARTIAL_NAME")
  requireLogin        Boolean              @default(false)
  redirectUrl         String?
  streamingUrl        String?
  videoEmbedUrl       String?
  overtimeSeconds     Int                  @default(120)
  activeLotId         String?
  activeLot           Lot?                 @relation("ActiveLot", fields: [activeLotId], references: [id])
  taxaAdministrativa  Float?
  comissaoLeiloeiro   Float?
  caucao              Boolean              @default(false)
  caucaoValor         Float?
  visitacaoLocal      String?
  visitacaoInicio     DateTime?
  visitacaoFim        DateTime?
  leiloeiroNome       String?
  leiloeiroMatricula  String?
  editalRegras        String?
  editalPdfUrl        String?
  comitenteId         String?
  comitente           Comitente?           @relation(fields: [comitenteId], references: [id])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  lots                Lot[]                @relation("AuctionLots")
  habilitacoes        AuctionHabilitacao[]
  internalControl     InternalControl?
}

model AuctionHabilitacao {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auctionId     String
  auction       Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  status        String   @default("PENDING")
  reason        String?
  agreedToTerms Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, auctionId])
}

model Comitente {
  id              String    @id @default(cuid())
  razaoSocial     String
  nomeFantasia    String?
  cnpjCpf         String    @unique
  contatoNome     String?
  contatoEmail    String?
  contatoTelefone String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  estado          String?
  cep             String?
  taxaComissao    Float?
  taxaFixa        Float?
  observacoes     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  auctions        Auction[]
}

model Lot {
  id                   String             @id @default(cuid())
  lotNumber            Int
  title                String
  description          String?
  category             String             @default("VEICULO")
  manufacturer         String?
  model                String?
  year                 String?
  color                String?
  fuel                 String?
  plate                String?
  chassis              String?
  location             String?
  startingPrice        Float
  incrementAmount      Float              @default(50.0)
  reservePrice         Float?
  currentBid           Float?
  currentBidderId      String?
  currentBidder        User?              @relation("LotCurrentBidder", fields: [currentBidderId], references: [id])
  status               String             @default("EM_ESTOQUE")
  condition            String?
  comitente            String?
  entrada              DateTime?
  saida                DateTime?
  despesaClassificacao String?
  placaUf              String?
  linhaVeiculo         String?
  versaoVeiculo        String?
  processoSei          String?
  orgaoContrato        String?
  patio                String?
  localPatio           String?
  fipeCodigo           String?
  fipeValor            Float?
  sucata               Boolean            @default(false)
  hasKeys              Boolean            @default(false)
  renavam              String?
  numeroMotor          String?
  accessories          String?
  modalidade           String?
  observacoes          String?
  observacoesInternas  String?
  imageUrl             String?
  auctionId            String
  auction              Auction            @relation("AuctionLots", fields: [auctionId], references: [id])
  activeInAuctions     Auction[]          @relation("ActiveLot")
  winnerId             String?
  winner               User?              @relation("LotWinner", fields: [winnerId], references: [id])
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  bids                 Bid[]
  images               LotImage[]
  logistics            LotLogistics?
  inspection           VehicleInspection?
}

model LotImage {
  id    String @id @default(cuid())
  url   String
  order Int    @default(0)
  lotId String
  lot   Lot    @relation(fields: [lotId], references: [id], onDelete: Cascade)
}

model LotLogistics {
  id              String   @id @default(cuid())
  lotId           String   @unique
  lot             Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  entryDate       DateTime @default(now())
  storageLocation String?
  keyLocation     String?
  hasKeys         Boolean  @default(false)
  hasManual       Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model VehicleInspection {
  id           String   @id @default(cuid())
  lotId        String   @unique
  lot          Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  inspectorId  String?
  inspector    User?    @relation(fields: [inspectorId], references: [id])
  engineStatus String?
  transmission String?
  bodywork     String?
  upholstery   String?
  checklist    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Bid {
  id        String   @id @default(cuid())
  amount    Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  lotId     String
  lot       Lot      @relation(fields: [lotId], references: [id])
  type      String   @default("MANUAL")
  timestamp DateTime @default(now())
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  position  String   @default("HOME_HERO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- INTERNAL CONTROL MODELS (Pátio Rocha Leilões) ---

model InternalControl {
  id                   String   @id @default(cuid())
  title                String
  type                 String   // Financeira, Seguradora, Prefeitura, Trânsito, Público Administrativo, Órgão Público, Extrajudicial, Judicial
  status               String   @default("PROSPECCAO") // PROSPECCAO, DOCUMENTACAO, AVALIACAO, PRONTO, PUBLICADO, SUSPENSO, CANCELADO
  
  // Organização Geral
  demands              String?  @db.Text
  meetings             String?  @db.Text
  inspections          String?  @db.Text
  tasks                String?  @db.Text // Tarefas internas
  notes                String?  @db.Text
  
  // Documentação Geral
  documents            InternalDocument[]
  
  // Judicial Specific Fields
  processNumber        String?
  parties              String?  // Partes do processo
  officialLettersSent  String?  @db.Text // Ofícios enviados
  importantDocsInfo    String?  @db.Text
  evaluationReportUrl  String?
  seizureInfo          String?  @db.Text // Penhora
  seizedPropertyDocs   String?  @db.Text
  edictUrl             String?
  auctionDate          DateTime?
  
  // Relation to public auction if/when linked
  auctionId            String?  @unique
  auction              Auction? @relation(fields: [auctionId], references: [id])
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model InternalDocument {
  id                String          @id @default(cuid())
  name              String
  url               String
  type              String?         // Ofício, Laudo, Edital, etc.
  internalControlId String
  internalControl   InternalControl @relation(fields: [internalControlId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
}

// --- RECICLADORA MODELS (from Recicladora Rocha) ---

model Salvado {
  id          String            @id @default(cuid())
  name        String
  description String?
  weight      Float?
  material    String?
  status      String            @default("PENDENTE")
  author      User              @relation(fields: [authorId], references: [id])
  authorId    String
  images      SalvadoImage[]
  documents   SalvadoDocument[]
  comments    Comment[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model SalvadoImage {
  id        String   @id @default(cuid())
  url       String
  salvado   Salvado  @relation(fields: [salvadoId], references: [id], onDelete: Cascade)
  salvadoId String
  createdAt DateTime @default(now())
}

model SalvadoDocument {
  id        String   @id @default(cuid())
  name      String
  url       String
  salvado   Salvado  @relation(fields: [salvadoId], references: [id], onDelete: Cascade)
  salvadoId String
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  salvado   Salvado  @relation(fields: [salvadoId], references: [id], onDelete: Cascade)
  salvadoId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- MARKETING MODELS ---

model MarketingGroup {
  id        Int                @id @default(autoincrement())
  name      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  contacts  MarketingContact[]
}

model MarketingContact {
  id         Int             @id @default(autoincrement())
  name       String
  email      String?
  phone      String?
  city       String?
  state      String?
  personType String          @default("PF")
  birthDate  String?
  groupId    Int?
  group      MarketingGroup? @relation(fields: [groupId], references: [id])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model MarketingCampaign {
  id             Int       @id @default(autoincrement())
  name           String
  type           String    @default("whatsapp")
  content        String
  subject        String?
  status         String    @default("scheduled")
  scheduledAt    DateTime?
  recipient      String?
  groupId        Int?
  filterState    String?
  filterCity     String?
  emailAccountId Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// --- CRM MODELS ---

model CrmLead {
  id               String   @id @default(cuid())
  name             String
  headline         String?
  company          String?
  location         String?
  email            String?
  phone            String?
  profileUrl       String?
  photoUrl         String?
  connectionDegree String?
  searchId         String?
  tags             String?  @default("[]")
  notes            String?
  status           String   @default("new")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  search           CrmSearch? @relation(fields: [searchId], references: [id])
}

model CrmSearch {
  id               String   @id @default(cuid())
  name             String
  keywords         String?
  jobTitles        String?  @default("[]")
  companies        String?  @default("[]")
  industries       String?  @default("[]")
  location         String?
  state            String?
  city             String?
  status           String   @default("pending")
  totalResults     Int      @default(0)
  processedPages   Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  leads            CrmLead[]
}

// --- LICITACOES MODELS ---

model LicitacaoBid {
  id        String   @id @default(cuid())
  title     String
  portal    String?
  match     String?  @default("95%")
  value     String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LicitacaoDocument {
  id        String   @id @default(cuid())
  name      String
  type      String?
  size      String?
  url       String?
  createdAt DateTime @default(now())
}

// --- ATELIE MODELS (from Laura Veríssimo) ---

model AtelieProduct {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       Float?
  imageUrl    String?
  category    String   @default("GERAL")
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)
}

model AtelieSettings {
  id       String @id @default(cuid())
  key      String @unique
  value    String
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
